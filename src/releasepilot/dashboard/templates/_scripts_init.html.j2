  openModal(_t('ui.first_run.schema'),
    '<p class="mb-2">'+_t('ui.schema.body_intro')+'</p>'+
    '<pre>{\n  "app_name": "MyApp",\n  "audience": "changelog",\n  "format": "markdown",\n  "language": "en",\n  "version": "1.2.0",\n  "show_authors": true,\n  "show_hashes": false\n}</pre>'+
    '<p class="mt-2 text-secondary">'+_t('ui.schema.supported_formats')+' <code>markdown</code>, <code>plaintext</code>, <code>json</code>, <code>pdf</code>, <code>docx</code></p>'+
    '<p class="text-secondary">'+_t('ui.schema.supported_audiences')+' <code>technical</code>, <code>user</code>, <code>summary</code>, <code>changelog</code>, <code>customer</code>, <code>executive</code>, <code>narrative</code></p>',
    '<button class="btn btn-secondary" onclick="closeModal()">' + _t('ui.modal.close') + '</button>'
  );
