/* ===== ARTIFACT LOOKUP ===== */
function findArtifact(audience,format){
  if(!D.artifacts)return null;
  for(var i=0;i<D.artifacts.length;i++){
    if(D.artifacts[i].audience===audience&&D.artifacts[i].format===format)return D.artifacts[i];
  }
  return null;
}
