/* ===== STEP 7: PIPELINE (dedicated generation screen) ===== */

function renderWizPipeline(){
  var content=$('#wiz-pipeline-content');
  var result=$('#wiz-generate-result');
  /* If generation already completed, show the result — not the spinner */
  if(S.wizard.generated && result && result.innerHTML.trim()){
    if(content)hideEl(content);
    showEl(result);
  } else {
    if(content)showEl(content);
    if(result)hideEl(result);
  }
}

function wizRunGenerate(){
  /* Navigate to pipeline step first */
  S.wizard.generated=false;
  wizGoStep(WIZ_STEP_PIPELINE);

  var cfg=_wizBuildFullConfig();
  if(!cfg){
    var result=$('#wiz-generate-result');
    var content=$('#wiz-pipeline-content');
    if(content)hideEl(content);
    if(result){result.innerHTML='<div class="alert alert-error">'+_t('ui.wizard.err_complete_scope')+'</div>';showEl(result)}
    return;
  }

  /* Send full config directly to dashboard — the body overrides state.config,
     ensuring the selected remote repository (not the local CWD) is used. */
  fetch('/api/dashboard',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cfg)})
    .then(function(r){return r.json()})
    .then(function(resp){
      var content=$('#wiz-pipeline-content');
      var result=$('#wiz-generate-result');
      if(content)hideEl(content);
      S.wizard.generated=true;
      if(resp&&resp.ok&&resp.data){
        for(var k in resp.data)if(resp.data.hasOwnProperty(k))D[k]=resp.data[k];
        var isBinary=(S.wizard.format==='pdf'||S.wizard.format==='docx');
        var art=findArtifact(S.wizard.audience,S.wizard.format);
        if(!art&&isBinary)art=findArtifact(S.wizard.audience,'markdown');
        if(art){
          var h='<div class="wizard-success">';
          h+='<div class="wizard-success-icon">&#9989;</div>';
          h+='<div class="wizard-success-title">'+_t('ui.wizard.generate_done')+'</div>';
          h+='<div class="wizard-success-text">'+_t('ui.wizard.generate_done_text')+'</div>';
          h+=_sourceBannerHtml();
          h+='<div class="stat-cards mt-2 wiz-gen-cards">';
          h+='<div class="stat-card accent"><div class="stat-card-value">'+D.total_changes+'</div><div class="stat-card-label">'+_t('ui.wizard.changes_count')+'</div></div>';
          h+='<div class="stat-card"><div class="stat-card-value">'+(art.size_bytes/1024).toFixed(1)+'</div><div class="stat-card-label">'+_t('ui.wizard.kb_output')+'</div></div>';
          h+='</div>';
          h+='<div class="flex gap-1 mt-2">';
          h+='<button class="btn btn-primary" onclick="wizGoStep('+WIZ_STEP_PREVIEW+')">&#128065; '+_t('ui.wizard.preview_export_btn')+'</button>';
          h+='<button class="btn" onclick="wizStartNew()">&#128260; '+_t('ui.wizard.start_new')+'</button>';
          h+='</div>';
          h+='</div>';
          if(result){result.innerHTML=h;showEl(result)}
        }else{
          var h2='<div class="wizard-success">';
          h2+='<div class="wizard-success-icon">&#9888;&#65039;</div>';
          h2+='<div class="wizard-success-title">'+_t('ui.wizard.no_artifact')+'</div>';
          h2+='<div class="flex gap-1 mt-2">';
          h2+='<button class="btn btn-sm" onclick="wizGoStep('+WIZ_STEP_SCOPE+')">&#9998; '+_t('ui.wizard.review_change_scope')+'</button>';
          h2+='<button class="btn btn-sm" onclick="wizStartNew()">&#128260; '+_t('ui.wizard.start_new')+'</button>';
          h2+='</div>';
          h2+='</div>';
          if(result){result.innerHTML=h2;showEl(result)}
        }
      }else{
        if(result){result.innerHTML='<div class="alert alert-error">'+esc(resp&&resp.error||_t('ui.error.generic'))+'</div><button class="btn btn-sm mt-2" onclick="wizStartNew()">&#128260; '+_t('ui.wizard.start_new')+'</button>';showEl(result)}
      }
    })
    .catch(function(e){
      var content=$('#wiz-pipeline-content');
      var result=$('#wiz-generate-result');
      if(content)hideEl(content);
      S.wizard.generated=true;
      if(result){result.innerHTML='<div class="alert alert-error">'+esc(typeof e==='string'?e:(e.message||_t('ui.error.generic')))+'</div><button class="btn btn-sm mt-2" onclick="wizStartNew()">&#128260; '+_t('ui.wizard.start_new')+'</button>';showEl(result)}
    });
}

function wizStartNew(){
  S.wizard.step=0;
  S.wizard.generated=false;
  var result=$('#wiz-generate-result');
  if(result){result.innerHTML='';hideEl(result)}
  renderWizard();
}

/* Build a complete pipeline config from the wizard's client-side state.
   Ensures remote repos include github_owner/repo/token (or gitlab equiv)
   so the pipeline uses the correct remote source — not the local CWD. */
var _GH_OWNER_RE=/github\.com[:/]([^/]+)\/([^/.#?]+)/;
function _wizBuildFullConfig(){
  var isRemote=_wizSourceState&&_wizSourceState.sourceType==='remote';
  var isDateMode=$('#src-opt-date')&&$('#src-opt-date').classList.contains('selected');
  var cfg={};
  var token=$('#src-remote-token')?$('#src-remote-token').value.trim():'';
  var verifySsl=$('#src-verify-ssl')?$('#src-verify-ssl').checked:true;

  if(isRemote){
    var provider=_wizSourceState.provider;
    var isMulti=_wizSourceState.repoCount==='multi';

    if(isMulti&&_wizSourceState.remoteRepos.length>0){
      /* Multi-repo remote: build multi_repo_sources */
      var sources=[];
      var labels=[];
      _wizSourceState.remoteRepos.forEach(function(r){
        var src={url:r.url,provider:r.provider||provider,app_label:r.label||r.url,verify_ssl:verifySsl};
        if(token)src.token=token;
        sources.push(src);
        labels.push(r.label||r.url);
      });
      cfg.multi_repo_sources=sources;
      cfg.app_name=labels.join(' + ');
      if(token){
        if(provider==='github')cfg.github_token=token;
        else cfg.gitlab_token=token;
      }
    }else{
      /* Single-repo remote */
      if(provider==='github'){
        var inspData=_wizSourceState.inspectedData;
        if(inspData&&inspData.repo){
          cfg.github_owner=inspData.repo.full_name.split('/')[0];
          cfg.github_repo=inspData.repo.name;
          cfg.app_name=inspData.repo.full_name;
        }else{
          /* Inspection may have been skipped (public repo / no token).
             Parse owner/repo directly from the URL. */
          var urlVal=$('#src-repo-url')?$('#src-repo-url').value.trim():'';
          var ghMatch=urlVal.match(_GH_OWNER_RE);
          if(ghMatch){cfg.github_owner=ghMatch[1];cfg.github_repo=ghMatch[2];cfg.app_name=ghMatch[1]+'/'+ghMatch[2]}
        }
        cfg.github_url='https://api.github.com';
        cfg.github_ssl_verify=verifySsl;
        if(token)cfg.github_token=token;
      }else{
        /* GitLab */
        var inspData2=_wizSourceState.inspectedData;
        if(inspData2&&inspData2.project){
          cfg.gitlab_project=inspData2.project.path;
          cfg.app_name=inspData2.project.path;
        }else{
          var glUrl=$('#src-repo-url')?$('#src-repo-url').value.trim():'';
          if(glUrl.indexOf('://')>=0){
            var pts=glUrl.split('://')[1].split('/');
            cfg.gitlab_project=pts.slice(1).join('/').replace(/\.git$/,'');
            cfg.app_name=cfg.gitlab_project;
          }
        }
        var glBase=$('#src-gitlab-url')?$('#src-gitlab-url').value.trim():'';
        if(glBase)cfg.gitlab_url=glBase;
        cfg.gitlab_ssl_verify=verifySsl;
        if(token)cfg.gitlab_token=token;
      }
    }
    /* Override app_name with explicit label if the user entered one */
    var labelVal=$('#src-repo-label')?$('#src-repo-label').value.trim():'';
    if(labelVal)cfg.app_name=labelVal;
  }else{
    /* Local source */
    cfg.source_type='local';
    if(_wizSourceState&&_wizSourceState.localMode==='directory'
       &&_wizSourceState.selectedLocalRepos&&_wizSourceState.selectedLocalRepos.length>0){
      var allDirRepos=_wizSourceState.localDirRepos||[];
      var sources=[];
      _wizSourceState.selectedLocalRepos.forEach(function(p){
        var match=allDirRepos.filter(function(r){return r.path===p})[0];
        sources.push({path:p,provider:'local',app_label:match?match.name:p.split('/').pop()});
      });
      cfg.multi_repo_sources=sources;
      cfg.repo_path=_wizSourceState.selectedLocalRepos[0];
    }
  }

  /* Scope / range */
  if(isDateMode){
    var sinceVal=$('#src-since-date')?$('#src-since-date').value:'';
    if(!sinceVal)return null;
    cfg.since_date=sinceVal;cfg.from_ref='';
    var branchVal=$('#src-branch-date')?$('#src-branch-date').value.trim():'';
    if(branchVal)cfg.branch=branchVal;
  }else{
    var fromVal=$('#src-from-ref')?$('#src-from-ref').value.trim():'';
    if(!fromVal)return null;
    cfg.from_ref=fromVal;cfg.since_date='';
    var toVal=$('#src-to-ref')?$('#src-to-ref').value.trim():'';
    if(toVal)cfg.to_ref=toVal;
  }

  /* Options from wizard state */
  if(S.wizard.audience)cfg.audience=S.wizard.audience;
  if(S.wizard.format)cfg.output_format=S.wizard.format;
  var langSel=$('#src-language');
  if(langSel)cfg.language=langSel.value;

  return cfg;
}

/* ===== STEP 7: PREVIEW & EXPORT ===== */

function renderWizPreviewExport(){
  var art=findArtifact(S.wizard.audience,S.wizard.format);
  var area=$('#wiz-preview-area');
  var meta=$('#wiz-preview-meta');
  var isBinary=(S.wizard.format==='pdf'||S.wizard.format==='docx');
  if(isBinary){
    var fallback=findArtifact(S.wizard.audience,'markdown');
    if(fallback){
      area.textContent=fallback.content;
      var info=AUDIENCE_INFO[S.wizard.audience]||{label:S.wizard.audience};
      var finfo=FORMAT_INFO[S.wizard.format]||{label:S.wizard.format};
      meta.innerHTML=info.label+' \u00b7 '+finfo.label+' <span class="wiz-preview-accent">'+_t('ui.wizard.binary_preview_note')+'</span>';
    }else{
      area.textContent=_t('ui.wizard.no_artifact');
      meta.textContent='';
    }
  } else if(art){
    area.textContent=art.content;
    var info=AUDIENCE_INFO[S.wizard.audience]||{label:S.wizard.audience};
    var finfo=FORMAT_INFO[S.wizard.format]||{label:S.wizard.format};
    meta.textContent=info.label+' \u00b7 '+finfo.label+' \u00b7 '+(art.size_bytes/1024).toFixed(1)+' KB';
  }else{
    area.textContent=_t('ui.wizard.no_artifact');
    meta.textContent='';
  }

  /* Populate export controls */
  var audSel=$('#wiz-export-audience');
  var fmtSel=$('#wiz-export-format');
  if(audSel){
    var h='';
    var auds=D.supported_audiences||Object.keys(AUDIENCE_INFO);
    auds.forEach(function(a){
      var info=AUDIENCE_INFO[a]||{label:a};
      h+='<option value="'+esc(a)+'"'+(S.wizard.audience===a?' selected':'')+'>'+esc(info.label)+'</option>';
    });
    audSel.innerHTML=h;
  }
  if(fmtSel)wizUpdateExportFormats();
  wizUpdateExport();
}

function wizCopyPreview(){
  var art=findArtifact(S.wizard.audience,S.wizard.format);
  if(art&&art.content){
    navigator.clipboard.writeText(art.content).then(function(){
      openModal(_t('ui.modal.copied_title'),'<p>'+_t('ui.modal.copied_text')+'</p>','<button class="btn btn-secondary" onclick="closeModal()">'+_t('ui.modal.ok')+'</button>');
    }).catch(function(){
      openModal(_t('ui.modal.copy_failed_title'),'<p>'+_t('ui.modal.copy_failed_text')+'</p>','<button class="btn btn-secondary" onclick="closeModal()">'+_t('ui.modal.ok')+'</button>');
    });
  }
}

function wizUpdateExportFormats(){
  var fmtSel=$('#wiz-export-format');
  if(!fmtSel)return;
  var aud=$('#wiz-export-audience')?$('#wiz-export-audience').value:S.wizard.audience;
  var isExec=(aud==='executive');
  var isNarr=(aud==='narrative'||aud==='customer-narrative');
  var allowed;
  if(isExec)allowed=['pdf','docx','markdown','json'];
  else if(isNarr)allowed=['pdf','docx','markdown','plaintext','json'];
  else allowed=['markdown','plaintext','json'];
  var curFmt=fmtSel.value||S.wizard.format;
  if(allowed.indexOf(curFmt)<0)curFmt=allowed[0];
  var h='';
  allowed.forEach(function(f){
    var info=FORMAT_INFO[f]||{label:f};
    h+='<option value="'+esc(f)+'"'+(curFmt===f?' selected':'')+'>'+esc(info.label)+'</option>';
  });
  fmtSel.innerHTML=h;
}
function wizUpdateExport(){
  var audEl=$('#wiz-export-audience');var fmtEl=$('#wiz-export-format');
  if(!audEl||!fmtEl)return;
  var aud=audEl.value;
  var fmt=fmtEl.value;
  var info=FORMAT_INFO[fmt]||{ext:'.txt',label:fmt};
  var fname=$('#wiz-export-filename');
  if(fname)fname.value='release-notes-'+aud+info.ext;
  var isBinary=(fmt==='pdf'||fmt==='docx');
  var art=findArtifact(aud,fmt);
  if(!art&&isBinary)art=findArtifact(aud,'markdown');
  var pre=$('#wiz-export-preview');
  if(pre){
    if(art){
      pre.textContent=art.content.substring(0,500)+(art.content.length>500?'\n\u2026':'');
      if(isBinary)pre.textContent='['+_t('ui.wizard.binary_export_note')+']\n\n'+pre.textContent;
    }else{
      pre.textContent=_t('ui.wizard.no_artifact');
    }
  }
}
function wizDoExport(){
  var aud=$('#wiz-export-audience').value;
  var fmt=$('#wiz-export-format').value;
  var fname=$('#wiz-export-filename').value||'release-notes.md';
  var isBinary=(fmt==='pdf'||fmt==='docx');
  var art=findArtifact(aud,fmt);
  if(!art&&isBinary)art=findArtifact(aud,'markdown');
  if(!art){openModal(_t('ui.modal.no_content_title'),'<p>'+_t('ui.wizard.no_artifact')+'</p>','<button class="btn btn-secondary" onclick="closeModal()">'+_t('ui.modal.ok')+'</button>');return}
  var blob=new Blob([art.content],{type:'text/plain;charset=utf-8'});
  var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=fname;a.click();URL.revokeObjectURL(a.href);
}
