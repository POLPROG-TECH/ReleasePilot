/* ===== WIZARD ===== */
/* Source selection state */
var _wizSourceState = {
  sourceType: 'local',   /* 'local' or 'remote' */
  localMode: 'current',  /* 'current' or 'directory' */
  repoCount: 'single',   /* 'single' or 'multi' */
  provider: 'github',    /* 'github' or 'gitlab' */
  tokenValidated: false,
  tokenSkipped: false,    /* true when user explicitly continues without token (public repo) */
  tokenUser: '',
  remoteRepos: [],        /* [{url, label, provider, owner, repo, inspected}] */
  inspectedData: null,    /* inspection result for single-repo mode */
  localDirRepos: [],      /* [{name, path}] — repos found in directory scan */
  selectedLocalRepos: []  /* [path] — user-selected repos from directory scan */
};

/* Step indices:
   0 = Source Type (local/remote)
   1 = Repositories
   2 = Scope (release range)
   3 = Audience
   4 = Format
   5 = Review
   6 = Pipeline (generation)
   7 = Preview & Export (post-generation)
*/
var WIZ_STEP_SOURCE = 0;
var WIZ_STEP_REPOS = 1;
var WIZ_STEP_SCOPE = 2;
var WIZ_STEP_AUDIENCE = 3;
var WIZ_STEP_FORMAT = 4;
var WIZ_STEP_REVIEW = 5;
var WIZ_STEP_PIPELINE = 6;
var WIZ_STEP_PREVIEW = 7;
var WIZ_TOTAL_TRACKED = 6; /* steps shown in stepper (0-5) */

/* ===== VALIDATION ENGINE ===== */

var _GH_URL_RE=/^https?:\/\/(?:www\.)?github\.com\/[A-Za-z0-9._-]+\/[A-Za-z0-9._-]+(?:\.git)?\/?$/;
var _GL_URL_RE=/^https?:\/\/[^\/]+\/[A-Za-z0-9._\/-]+(?:\.git)?\/?$/;
var _DATE_RE=/^\d{4}-\d{2}-\d{2}$/;

/* Detect GitHub org/user page URLs (not a specific repository) */
var _GH_ORG_RE=/^https?:\/\/(?:www\.)?github\.com\/(?:orgs\/)?([A-Za-z0-9._-]+)(?:\/(?:repositories|members|teams|projects|packages|people)?\/?)?$/i;
/* Detect GitLab group-level URLs (single segment after host = group, not project) */
var _GL_GROUP_RE=/^(https?:\/\/[^\/]+)\/([A-Za-z0-9._-]+)\/?$/i;

function _wizShowFieldError(inputId,errId,msg){
  var inp=$(inputId);
  var err=$(errId);
  if(inp){inp.classList.add('invalid');inp.classList.remove('valid')}
  if(err){err.textContent=msg;err.classList.add('visible')}
}

function _wizClearFieldError(inputId,errId){
  var inp=$(inputId);
  var err=$(errId);
  if(inp)inp.classList.remove('invalid','valid');
  if(err){err.textContent='';err.classList.remove('visible')}
}

function _wizClearStepErrors(stepNum){
  var el=$('#wiz-step'+stepNum+'-errors');
  if(el)el.innerHTML='';
  /* Clear all field errors within the step panel */
  var panel=$('#wiz-panel-'+stepNum);
  if(panel){
    panel.querySelectorAll('.field-error.visible').forEach(function(e){e.textContent='';e.classList.remove('visible')});
    panel.querySelectorAll('.form-input.invalid,.form-select.invalid').forEach(function(e){e.classList.remove('invalid')});
  }
}

function _wizShowStepError(stepNum,msg){
  var el=$('#wiz-step'+stepNum+'-errors');
  if(el)el.innerHTML='<div class="alert alert-error">'+msg+'</div>';
}

function _wizMarkFieldValid(inputId){
  var inp=$(inputId);
  if(inp){inp.classList.remove('invalid');inp.classList.add('valid')}
}

/** Validate a specific step. Returns {valid: bool, errors: string[]} */
function _wizValidateStep(n){
  var errors=[];

  if(n===WIZ_STEP_SOURCE){
    /* Source step is always valid — local mode details are validated in repos step */
  }

  else if(n===WIZ_STEP_REPOS){
    _wizClearStepErrors(n);
    if(_wizSourceState.sourceType==='remote'){
      /* Token: required only if not skipped (public repo) and not validated */
      var hasToken=!!($('#src-remote-token')?$('#src-remote-token').value.trim():'');
      var tokenOk=_wizSourceState.tokenValidated||_wizSourceState.tokenSkipped;

      /* GitHub: auto-skip token if none entered — public repos work without it */
      if(_wizSourceState.provider==='github'&&!hasToken&&!tokenOk){
        _wizSourceState.tokenSkipped=true;
        tokenOk=true;
      }

      if(!tokenOk&&hasToken){
        errors.push(_t('ui.wizard.err_validate_token'));
      }
      /* GitLab needs URL */
      if(_wizSourceState.provider==='gitlab'){
        var glUrl=$('#src-gitlab-url')?$('#src-gitlab-url').value.trim():'';
        if(!glUrl){
          _wizShowFieldError('#src-gitlab-url','#err-gitlab-url',_t('ui.wizard.err_gitlab_url_required'));
          errors.push(_t('ui.wizard.err_gitlab_url_missing'));
        }else if(!/^https?:\/\/.+/.test(glUrl)){
          _wizShowFieldError('#src-gitlab-url','#err-gitlab-url',_t('ui.wizard.err_gitlab_url_format'));
          errors.push(_t('ui.wizard.err_gitlab_url_invalid'));
        }
        /* GitLab always requires a token */
        if(!hasToken&&!_wizSourceState.tokenValidated){
          _wizShowFieldError('#src-remote-token','#err-remote-token',_t('ui.wizard.err_token_required_private'));
          if(errors.indexOf(_t('ui.wizard.err_validate_token'))<0)
            errors.push(_t('ui.wizard.err_token_enter'));
        }
      }

      /* Repository selection */
      if(tokenOk||_wizSourceState.provider==='github'){
        if(_wizSourceState.repoCount==='single'){
          var repoUrl=$('#src-repo-url')?$('#src-repo-url').value.trim():'';
          if(!repoUrl){
            _wizShowFieldError('#src-repo-url','#err-repo-url',_t('ui.wizard.err_repo_url_required'));
            errors.push(_t('ui.wizard.err_repo_url_missing'));
          }else{
            var urlRe=_wizSourceState.provider==='github'?_GH_URL_RE:_GL_URL_RE;
            if(!urlRe.test(repoUrl)){
              _wizShowFieldError('#src-repo-url','#err-repo-url',
                _wizSourceState.provider==='github'
                  ?_t('ui.wizard.err_github_url_format')
                  :_t('ui.wizard.err_gitlab_repo_url_format'));
              errors.push(_t('ui.wizard.err_repo_url_invalid'));
            }else{
              _wizMarkFieldValid('#src-repo-url');
            }
          }
        }else{
          /* Multi-repo: at least one must be added */
          if(!_wizSourceState.remoteRepos.length){
            errors.push(_t('ui.wizard.err_add_repo'));
          }
        }
      }
    }else{
      /* Local mode */
      if(_wizSourceState.localMode==='directory'){
        /* Directory scan mode — must have scanned and selected repos */
        var dirPath=$('#src-local-dir-path')?$('#src-local-dir-path').value.trim():'';
        if(!dirPath){
          _wizShowFieldError('#src-local-dir-path','#err-local-dir-path',_t('ui.wizard.err_dir_path_required'));
          errors.push(_t('ui.wizard.err_dir_path_missing'));
        }else if(!_wizSourceState.localDirRepos||!_wizSourceState.localDirRepos.length){
          errors.push(_t('ui.wizard.err_scan_required'));
        }else if(!_wizSourceState.selectedLocalRepos||!_wizSourceState.selectedLocalRepos.length){
          errors.push(_t('ui.wizard.err_select_repo'));
        }
      }else{
        /* Current repo mode — check no fatal git errors */
        if(_hasGitError()){
          errors.push(_t('ui.wizard.err_not_git_repo'));
        }
      }
    }
  }

  else if(n===WIZ_STEP_SCOPE){
    _wizClearStepErrors(n);
    var isDateMode=$('#src-opt-date')&&$('#src-opt-date').classList.contains('selected');
    if(isDateMode!==false&&isDateMode){
      var sinceVal=$('#src-since-date')?$('#src-since-date').value:'';
      if(!sinceVal){
        errors.push(_t('ui.wizard.err_date_required'));
      }else if(!_DATE_RE.test(sinceVal)){
        errors.push(_t('ui.wizard.err_date_format'));
      }else{
        var d=new Date(sinceVal);
        if(isNaN(d.getTime())){
          errors.push(_t('ui.wizard.err_date_invalid'));
        }else if(d>new Date()){
          errors.push(_t('ui.wizard.err_date_future'));
        }
      }
    }else{
      var fromRef=$('#src-from-ref')?$('#src-from-ref').value.trim():'';
      if(!fromRef){
        errors.push(_t('ui.wizard.err_ref_required'));
      }
    }
  }

  else if(n===WIZ_STEP_AUDIENCE){
    if(!S.wizard.audience){
      errors.push(_t('ui.wizard.err_select_audience'));
    }
  }

  else if(n===WIZ_STEP_FORMAT){
    if(!S.wizard.format){
      errors.push(_t('ui.wizard.err_select_format'));
    }
  }

  return {valid:errors.length===0,errors:errors};
}

/** Update the Next button disabled state based on current step validity */
function _wizUpdateNextBtn(){
  var nextBtn=$('#wiz-next-btn');
  if(!nextBtn)return;
  var s=S.wizard.step;
  if(s>=WIZ_STEP_REVIEW){nextBtn.disabled=true;return}
  var result=_wizValidateStep(s);
  _wizClearStepErrors(s); /* Don't show errors on passive check */
  nextBtn.disabled=!result.valid;
}

function launchWizard(){
  S.wizard.audience=D.audience||'changelog';
  S.wizard.format=D.output_format||'markdown';
  S.wizard.step=0;
  S.wizard.generated=false;
  switchTab('generate');
}

function renderWizard(){
  wizGoStep(S.wizard.step);
}

function wizGoStep(n){
  if(n>0&&_hasGitError()&&_wizSourceState.sourceType==='local'&&_wizSourceState.localMode!=='directory')return;
  S.wizard.step=n;
  /* Update stepper indicators (only steps 0-5 are in the stepper) */
  $$('[data-wiz-step]').forEach(function(s){
    var si=parseInt(s.dataset.wizStep,10);
    s.classList.toggle('active',si===n||(n>=WIZ_STEP_PIPELINE&&si===WIZ_STEP_REVIEW));
    s.classList.toggle('done',si<n&&si<WIZ_STEP_PIPELINE);
    s.classList.remove('has-error');
  });
  /* Show the correct panel */
  $$('.wizard-panel').forEach(function(p,i){p.classList.toggle('active',i===n)});
  /* Footer visibility — hide for review, pipeline, preview */
  var footer=$('#wizard-footer');
  if(n>=WIZ_STEP_REVIEW){hideEl(footer)}else{showEl(footer)}
  var prevBtn=$('#wiz-prev-btn');
  if(prevBtn){prevBtn.disabled=(n===0);if(n===0)hideEl(prevBtn);else showEl(prevBtn)}
  var nextBtn=$('#wiz-next-btn');
  if(nextBtn){
    if(n===WIZ_STEP_FORMAT)nextBtn.innerHTML='<span>'+_t('ui.wizard.review_step')+'</span> &#8594;';
    else nextBtn.innerHTML='<span>'+_t('ui.wizard.next')+'</span> &#8594;';
  }
  /* Render step content */
  if(n===WIZ_STEP_SOURCE)renderWizSourceStep();
  if(n===WIZ_STEP_REPOS)renderWizReposStep();
  if(n===WIZ_STEP_SCOPE)renderWizScopeStep();
  if(n===WIZ_STEP_AUDIENCE)renderWizAudience();
  if(n===WIZ_STEP_FORMAT)renderWizFormat();
  if(n===WIZ_STEP_REVIEW)renderWizReview();
  if(n===WIZ_STEP_PIPELINE)renderWizPipeline();
  if(n===WIZ_STEP_PREVIEW)renderWizPreviewExport();
  /* Update button state after render */
  setTimeout(_wizUpdateNextBtn,50);
}

function _hasGitError(){
  if(!D.diagnostics||!D.diagnostics.length)return false;
  for(var i=0;i<D.diagnostics.length;i++){
    var d=D.diagnostics[i].toLowerCase();
    if(d.indexOf('not a git repository')>=0||d.indexOf('git command failed')>=0||d.indexOf('fatal:')>=0)return true;
  }
  return false;
}

function wizPrev(){if(S.wizard.step>0)wizGoStep(S.wizard.step-1)}
function wizNext(){
  var s=S.wizard.step;
  if(s>=WIZ_STEP_REVIEW)return;

  /* Validate current step */
  var result=_wizValidateStep(s);
  if(!result.valid){
    /* Show errors */
    _wizShowStepError(s,'&#9888;&#65039; '+result.errors[0]);
    /* Mark step indicator as having an error */
    var stepEl=document.querySelector('[data-wiz-step="'+s+'"]');
    if(stepEl)stepEl.classList.add('has-error');
    return;
  }
  _wizClearStepErrors(s);
  wizGoStep(s+1);
}

/* ===== STEP 1: SOURCE TYPE ===== */

function renderWizSourceStep(){
  /* Just ensure correct selection state on the cards */
  var localOpt=$('#src-type-local'),remoteOpt=$('#src-type-remote');
  if(_wizSourceState.sourceType==='local'){
    localOpt.classList.add('selected');localOpt.setAttribute('aria-checked','true');
    remoteOpt.classList.remove('selected');remoteOpt.setAttribute('aria-checked','false');
  }else{
    remoteOpt.classList.add('selected');remoteOpt.setAttribute('aria-checked','true');
    localOpt.classList.remove('selected');localOpt.setAttribute('aria-checked','false');
  }
}

function wizSelectSourceType(type){
  _wizSourceState.sourceType=type;
  renderWizSourceStep();
}

/* ===== STEP 2: REPOSITORIES ===== */

function renderWizReposStep(){
  var isRemote=_wizSourceState.sourceType==='remote';
  var localSection=$('#wiz-repos-local');
  var remoteSection=$('#wiz-repos-remote');

  if(isRemote){
    hideEl(localSection);showEl(remoteSection);
    wizSelectProvider(_wizSourceState.provider);
    _wizUpdateRemoteRepoVisibility();
  }else{
    showEl(localSection);hideEl(remoteSection);
    _renderLocalRepoInfo();
  }
}

function _renderLocalRepoInfo(){
  var h='';

  if(_hasGitError()){
    h+='<div class="wiz-fatal-error">';
    h+='<div class="wiz-fatal-icon">&#128721;</div>';
    h+='<div class="wiz-fatal-title">'+_t('ui.wizard.no_repo_title')+'</div>';
    h+='<div class="wiz-fatal-text">'+_t('ui.wizard.no_repo_text')+'</div>';
    h+='<div class="wiz-fatal-details">';
    D.diagnostics.forEach(function(d){h+='<div class="wiz-fatal-line">'+esc(d)+'</div>'});
    h+='</div>';
    h+='<div class="wiz-fatal-hint">'+_t('ui.wizard.no_repo_hint')+'</div>';
    h+='</div>';
    $('#wiz-local-repo-info').innerHTML=h;
    hideEl($('#wiz-local-mode-select'));
    hideEl($('#wiz-local-dir-section'));
    return;
  }

  var repoName='';
  if(D.repo_path)repoName=D.repo_path.replace(/\\/g,'/').split('/').filter(function(s){return s}).pop()||D.repo_path;
  var displayName=D.app_name||repoName||_t('ui.wizard.unknown_repo');

  /* Rich repository metadata card */
  h+='<div class="wiz-repo-card">';
  h+='<div class="wiz-repo-card-header">';
  h+='<div class="wiz-repo-card-icon">&#128193;</div>';
  h+='<div class="wiz-repo-card-title">';
  h+='<div class="wiz-repo-card-name">'+esc(displayName)+'</div>';
  if(D.repo_path)h+='<div class="wiz-repo-card-path">'+esc(D.repo_path)+'</div>';
  h+='</div>';
  h+='</div>';

  h+='<div class="wiz-repo-card-meta">';
  if(D.branch){
    h+='<div class="wiz-repo-meta-item">';
    h+='<span class="wiz-repo-meta-label">'+_t('ui.wizard.branch')+'</span>';
    h+='<span class="wiz-repo-meta-value wiz-branch-tag">'+esc(D.branch)+'</span>';
    h+='</div>';
  }
  if(D.version){
    h+='<div class="wiz-repo-meta-item">';
    h+='<span class="wiz-repo-meta-label">'+_t('ui.wizard.meta_version')+'</span>';
    h+='<span class="wiz-repo-meta-value">v'+esc(D.version)+'</span>';
    h+='</div>';
  }
  if(D.total_changes!=null){
    h+='<div class="wiz-repo-meta-item">';
    h+='<span class="wiz-repo-meta-label">'+_t('ui.wizard.meta_total_commits')+'</span>';
    h+='<span class="wiz-repo-meta-value">'+D.total_changes+'</span>';
    h+='</div>';
  }
  if(D.last_activity){
    h+='<div class="wiz-repo-meta-item">';
    h+='<span class="wiz-repo-meta-label">'+_t('ui.wizard.meta_last_activity')+'</span>';
    h+='<span class="wiz-repo-meta-value">'+esc(D.last_activity)+'</span>';
    h+='</div>';
  }
  if(D.source_type){
    h+='<div class="wiz-repo-meta-item">';
    h+='<span class="wiz-repo-meta-label">'+_t('ui.wizard.review_source')+'</span>';
    h+='<span class="wiz-repo-meta-value">'+esc(D.source_type)+'</span>';
    h+='</div>';
  }
  h+='</div>';
  h+='<div class="wiz-repo-card-status">&#9989; '+_t('ui.wizard.repo_accessible')+'</div>';
  h+='</div>';

  h+='<p class="text-secondary mt-1">'+_t('ui.wizard.local_repo_ready_text')+'</p>';

  $('#wiz-local-repo-info').innerHTML=h;
  showEl($('#wiz-local-mode-select'));

  /* Restore local mode selection state */
  wizSelectLocalMode(_wizSourceState.localMode||'current');
}

/* ===== LOCAL MODE: current repo vs directory scan ===== */

function wizSelectLocalMode(mode){
  _wizSourceState.localMode=mode;
  var curOpt=$('#local-mode-current');
  var dirOpt=$('#local-mode-directory');
  var dirSection=$('#wiz-local-dir-section');

  if(curOpt){curOpt.classList.toggle('selected',mode==='current');curOpt.setAttribute('aria-checked',mode==='current'?'true':'false')}
  if(dirOpt){dirOpt.classList.toggle('selected',mode==='directory');dirOpt.setAttribute('aria-checked',mode==='directory'?'true':'false')}

  if(mode==='directory'){
    showEl(dirSection);
  }else{
    hideEl(dirSection);
    /* Clear directory scan state when switching back */
    _wizSourceState.localDirRepos=[];
    _wizSourceState.selectedLocalRepos=[];
  }
  _wizUpdateNextBtn();
}

function wizScanDirectory(){
  var pathInput=$('#src-local-dir-path');
  var errEl=$('#err-local-dir-path');
  var resultEl=$('#wiz-dir-scan-result');
  var listEl=$('#wiz-dir-repo-list');
  var path=pathInput?pathInput.value.trim():'';

  /* Clear previous */
  if(errEl)errEl.textContent='';
  if(resultEl)resultEl.innerHTML='';
  if(listEl)listEl.innerHTML='';
  if(pathInput)pathInput.classList.remove('invalid','valid');

  if(!path){
    if(errEl)errEl.textContent='Please enter a directory path.';
    if(pathInput)pathInput.classList.add('invalid');
    return;
  }

  /* Show loading */
  if(resultEl)resultEl.innerHTML='<div class="text-secondary">&#128269; '+_t('ui.wizard.scanning_dir')+'</div>';

  fetch('/api/scan-directory',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:path})})
    .then(function(r){return r.json()})
    .then(function(d){
      if(!d||!d.ok){
        if(pathInput)pathInput.classList.add('invalid');
        if(errEl)errEl.textContent=d&&d.error||_t('ui.wizard.err_scan_failed');
        if(resultEl)resultEl.innerHTML='';
        return;
      }
      if(pathInput)pathInput.classList.add('valid');
      _wizSourceState.localDirRepos=d.repos||[];
      _wizSourceState.selectedLocalRepos=d.repos.map(function(r){return r.path});
      if(resultEl)resultEl.innerHTML='<div class="alert alert-info">&#9989; '+_t('ui.wizard.scan_found').replace('{count}',d.count)+'</div>';
      _renderLocalDirRepoList();
    })
    .catch(function(e){
      if(pathInput)pathInput.classList.add('invalid');
      if(errEl)errEl.textContent=typeof e==='string'?e:(e.message||_t('ui.wizard.err_scan_failed'));
      if(resultEl)resultEl.innerHTML='';
    });
}

function _renderLocalDirRepoList(){
  var listEl=$('#wiz-dir-repo-list');
  if(!listEl)return;
  var repos=_wizSourceState.localDirRepos||[];
  if(repos.length===0){listEl.innerHTML='';return}

  var h='<div class="wiz-dir-repo-header flex gap-1 mb-1">';
  h+='<button class="btn btn-sm" onclick="_wizToggleAllLocalRepos(true)">Select All</button>';
  h+='<button class="btn btn-sm" onclick="_wizToggleAllLocalRepos(false)">Deselect All</button>';
  h+='<span class="text-secondary" id="wiz-dir-selected-count">'+repos.length+' of '+repos.length+' selected</span>';
  h+='</div>';

  repos.forEach(function(r,i){
    var checked=(_wizSourceState.selectedLocalRepos||[]).indexOf(r.path)>=0;
    h+='<label class="wiz-dir-repo-item">';
    h+='<input type="checkbox" '+(checked?'checked':'')+' onchange="_wizToggleLocalRepo('+i+')">';
    h+='<span class="wiz-dir-repo-name">'+esc(r.name)+'</span>';
    h+='<span class="wiz-dir-repo-path">'+esc(r.path)+'</span>';
    h+='</label>';
  });
  listEl.innerHTML=h;
}

function _wizToggleLocalRepo(idx){
  var repos=_wizSourceState.localDirRepos||[];
  if(idx<0||idx>=repos.length)return;
  var path=repos[idx].path;
  var sel=_wizSourceState.selectedLocalRepos||[];
  var pos=sel.indexOf(path);
  if(pos>=0)sel.splice(pos,1);
  else sel.push(path);
  _wizSourceState.selectedLocalRepos=sel;
  _updateLocalDirSelectedCount();
  _wizUpdateNextBtn();
}

function _wizToggleAllLocalRepos(selectAll){
  var repos=_wizSourceState.localDirRepos||[];
  if(selectAll){
    _wizSourceState.selectedLocalRepos=repos.map(function(r){return r.path});
  }else{
    _wizSourceState.selectedLocalRepos=[];
  }
  _renderLocalDirRepoList();
  _wizUpdateNextBtn();
}

function _updateLocalDirSelectedCount(){
  var el=$('#wiz-dir-selected-count');
  if(!el)return;
  var total=(_wizSourceState.localDirRepos||[]).length;
  var sel=(_wizSourceState.selectedLocalRepos||[]).length;
  el.textContent=sel+' of '+total+' selected';
}

function wizSelectProvider(provider){
  _wizSourceState.provider=provider;
  $$('.wiz-provider-opt').forEach(function(el){
    var p=el.id.replace('src-provider-','');
    el.classList.toggle('selected',p===provider);
  });
  var glRow=$('#wiz-gitlab-url-row');
  var tokenHint=$('#src-token-hint');
  var repoUrl=$('#src-repo-url');
  var multiRepoUrl=$('#src-multi-repo-url');
  var optionalHint=$('#src-token-optional-hint');
  var requiredStar=$('#src-token-required-star');
  var skipBtn=$('#btn-skip-token');
  if(provider==='gitlab'){
    glRow.style.display='';
    if(tokenHint)tokenHint.textContent=_t('ui.wizard.token_hint_gitlab');
    if(repoUrl)repoUrl.placeholder='https://gitlab.example.com/owner/repo';
    if(multiRepoUrl)multiRepoUrl.placeholder='https://gitlab.example.com/owner/repo';
    /* GitLab always requires token */
    if(optionalHint)optionalHint.style.display='none';
    if(requiredStar)requiredStar.style.display='';
    if(skipBtn)skipBtn.style.display='none';
  }else{
    glRow.style.display='none';
    if(tokenHint)tokenHint.textContent=_t('ui.wizard.token_hint_github');
    if(repoUrl)repoUrl.placeholder='https://github.com/owner/repo';
    if(multiRepoUrl)multiRepoUrl.placeholder='https://github.com/owner/repo';
    /* GitHub: token optional for public repos — auto-skipped on next step */
    if(optionalHint)optionalHint.style.display='';
    if(requiredStar)requiredStar.style.display='none';
    if(skipBtn)skipBtn.style.display='none';
  }
  _wizSourceState.tokenValidated=false;
  _wizSourceState.tokenSkipped=false;
  _wizSourceState.tokenUser='';
  var statusEl=$('#src-token-status');if(statusEl)statusEl.textContent='';
  _wizHideRepoInput();
  _wizUpdateRemoteRepoVisibility();
}

function _wizHideRepoInput(){
  /* No longer hides #wiz-repo-input-section — it's always visible */
  /* Only clear inspection results when switching providers */
  var inspResult=$('#src-repo-inspect-result');if(inspResult)inspResult.innerHTML='';
}

function _wizUpdateRemoteRepoVisibility(){
  var isSingle=_wizSourceState.repoCount==='single';
  var singleEl=$('#wiz-remote-repo-single');
  var multiEl=$('#wiz-remote-repo-multi');
  var gatedHint=$('#wiz-token-gated-hint');
  var inspectBtn=$('#btn-inspect-repo');
  var inspectHint=$('#inspect-token-hint');
  /* Repo input section is always visible — only toggle single/multi */
  if(isSingle){showEl(singleEl);hideEl(multiEl)}
  else{hideEl(singleEl);showEl(multiEl);wizRenderMultiRepoList()}
  /* Show/hide the gated hint and enable/disable inspect based on token */
  var validated=_wizSourceState.tokenValidated;
  var skipped=_wizSourceState.tokenSkipped;
  var isGitHub=_wizSourceState.provider==='github';
  if(gatedHint){
    /* For GitHub, hide the gate — token is optional and auto-skipped */
    if(validated||skipped||isGitHub)hideEl(gatedHint);
    else showEl(gatedHint);
  }
  if(inspectBtn){inspectBtn.disabled=!validated}
  if(inspectHint){inspectHint.style.display=validated?'none':''}
}

function wizSelectRepoCount(count){
  _wizSourceState.repoCount=count;
  var singleOpt=$('#src-count-single'),multiOpt=$('#src-count-multi');
  if(count==='single'){
    singleOpt.classList.add('selected');singleOpt.setAttribute('aria-checked','true');
    multiOpt.classList.remove('selected');multiOpt.setAttribute('aria-checked','false');
  }else{
    multiOpt.classList.add('selected');multiOpt.setAttribute('aria-checked','true');
    singleOpt.classList.remove('selected');singleOpt.setAttribute('aria-checked','false');
  }
  _wizUpdateRemoteRepoVisibility();
}

function wizValidateToken(){
  _wizClearFieldError('#src-remote-token','#err-remote-token');
  _wizClearFieldError('#src-gitlab-url','#err-gitlab-url');
  var token=$('#src-remote-token').value.trim();
  if(!token){_wizShowFieldError('#src-remote-token','#err-remote-token',_t('ui.wizard.err_token_empty'));return}

  _wizSourceState.tokenSkipped=false;
  var provider=_wizSourceState.provider;
  var statusEl=$('#src-token-status');
  statusEl.innerHTML='<span class="text-secondary">'+_t('ui.wizard.validating')+'</span>';
  var verifySsl=$('#src-verify-ssl')?$('#src-verify-ssl').checked:true;

  var endpoint,body;
  if(provider==='github'){
    endpoint='/api/github/validate';
    body={github_token:token,github_ssl_verify:verifySsl};
  }else{
    var gitlabUrl=$('#src-gitlab-url').value.trim();
    if(!gitlabUrl){_wizShowFieldError('#src-gitlab-url','#err-gitlab-url',_t('ui.wizard.err_gitlab_url_required'));statusEl.textContent='';return}
    endpoint='/api/gitlab/validate';
    body={gitlab_url:gitlabUrl,gitlab_token:token,gitlab_ssl_verify:verifySsl};
  }

  fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.ok){
        _wizSourceState.tokenValidated=true;
        _wizSourceState.tokenSkipped=false;
        _wizSourceState.tokenUser=d.user||d.name||'';
        _wizMarkFieldValid('#src-remote-token');
        statusEl.innerHTML='<span class="text-success">&#9989; '+_t('ui.wizard.token_authenticated')+' <strong>'+esc(d.user||d.name||'user')+'</strong></span>';
        _wizUpdateRemoteRepoVisibility();
        var cfgBody={};
        if(provider==='github'){cfgBody.github_token=token;cfgBody.source_type='github';cfgBody.github_ssl_verify=verifySsl}
        else{
          cfgBody.gitlab_token=token;cfgBody.gitlab_url=$('#src-gitlab-url').value.trim();cfgBody.source_type='gitlab';cfgBody.gitlab_ssl_verify=verifySsl;
        }
        fetch('/api/config',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(cfgBody)});
      }else{
        _wizSourceState.tokenValidated=false;
        _wizShowFieldError('#src-remote-token','#err-remote-token',d.error||_t('ui.wizard.err_token_validation_failed'));
        statusEl.innerHTML='<span class="text-error">&#10060; '+esc(d.error||_t('ui.wizard.err_token_validation_failed'))+'</span>';
      }
      _wizUpdateNextBtn();
    })
    .catch(function(e){
      statusEl.innerHTML='<span class="text-error">&#10060; '+esc(e.message||'Connection error')+'</span>';
      _wizUpdateNextBtn();
    });
}

function wizSkipToken(){
  /* Allow proceeding without token (GitHub public repos only) */
  _wizSourceState.tokenSkipped=true;
  _wizSourceState.tokenValidated=false;
  _wizSourceState.tokenUser='';
  _wizClearFieldError('#src-remote-token','#err-remote-token');
  var statusEl=$('#src-token-status');
  if(statusEl)statusEl.innerHTML='<span class="text-secondary">&#9432; '+_t('ui.wizard.token_skipped_status')+'</span>';
  _wizUpdateRemoteRepoVisibility();
  _wizUpdateNextBtn();
}

function wizInspectRepo(){
  _wizClearFieldError('#src-repo-url','#err-repo-url');
  var url=$('#src-repo-url').value.trim();
  if(!url){_wizShowFieldError('#src-repo-url','#err-repo-url',_t('ui.wizard.err_repo_url_inspect'));return}

  /* Detect org/user pages → suggest switching to multi-repo mode */
  var orgCheck=_wizDetectOrgUrl(url);
  if(orgCheck.isOrg){
    _wizShowFieldError('#src-repo-url','#err-repo-url',_t('ui.wizard.err_org_use_multi'));
    return;
  }

  var urlRe=_wizSourceState.provider==='github'?_GH_URL_RE:_GL_URL_RE;
  if(!urlRe.test(url)){
    _wizShowFieldError('#src-repo-url','#err-repo-url',
      _wizSourceState.provider==='github'
        ?_t('ui.wizard.err_github_url_format')
        :_t('ui.wizard.err_gitlab_repo_url_format'));
    return;
  }

  var resultEl=$('#src-repo-inspect-result');
  resultEl.innerHTML='<div class="text-secondary">'+_t('ui.wizard.inspecting')+'</div>';

  var provider=_wizSourceState.provider;
  var endpoint,body;
  if(provider==='github'){
    endpoint='/api/github/inspect';
    body={url:url};
  }else{
    var projectPath=url;
    if(url.indexOf('://')>=0){
      var parts=url.split('://')[1].split('/');
      projectPath=parts.slice(1).join('/').replace(/\.git$/,'');
    }
    endpoint='/api/gitlab/inspect';
    body={project:projectPath};
  }

  fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.ok){
        _wizSourceState.inspectedData=d;
        var h='<div class="alert alert-success">&#9989; <strong>'+_t('ui.wizard.repo_accessible')+'</strong></div>';
        var name=(d.repo?d.repo.full_name:d.project?d.project.path:'');
        if(name)h+='<div class="text-secondary">'+esc(name)+'</div>';
        if(d.default_branch)h+='<div class="text-secondary">'+_t('ui.wizard.inspect_default_branch')+': <code>'+esc(d.default_branch)+'</code></div>';
        if(d.branches)h+='<div class="text-secondary">'+_t('ui.wizard.inspect_branches')+': '+d.branches.length+' &middot; '+_t('ui.wizard.inspect_tags')+': '+(d.tags?d.tags.length:0)+'</div>';
        var labelInput=$('#src-repo-label');
        if(labelInput&&!labelInput.value)labelInput.value=name||'';
        var cfgBody={source_type:provider};
        if(provider==='github'){
          cfgBody.github_owner=d.repo?d.repo.full_name.split('/')[0]:'';
          cfgBody.github_repo=d.repo?d.repo.name:'';
        }else{
          cfgBody.gitlab_project=d.project?d.project.path:'';
        }
        if(d.default_branch)cfgBody.branch=d.default_branch;
        fetch('/api/config',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(cfgBody)});
        resultEl.innerHTML=h;
        _wizMarkFieldValid('#src-repo-url');
        _wizUpdateNextBtn();
      }else{
        resultEl.innerHTML='<div class="alert alert-error">&#10060; '+esc(d.error||_t('ui.wizard.err_inspection_failed'))+'</div>';
        _wizShowFieldError('#src-repo-url','#err-repo-url',d.error||_t('ui.wizard.err_inspection_failed'));
      }
    })
    .catch(function(e){
      resultEl.innerHTML='<div class="alert alert-error">&#10060; '+esc(e.message||'Connection error')+'</div>';
    });
}

/* ===== MULTI-REPO MANAGEMENT ===== */

/* ── Org/Group Discovery ── */
var _orgDiscoveryState={loading:false,repos:[],org:'',provider:'',error:''};

function _wizDetectOrgUrl(url){
  /* Returns {isOrg:true,org:'NAME',provider:'github'|'gitlab'} or {isOrg:false} */
  if(_wizSourceState.provider==='github'){
    var m=url.match(_GH_ORG_RE);
    if(m)return{isOrg:true,org:m[1],provider:'github'};
  }else{
    var m2=url.match(_GL_GROUP_RE);
    if(m2)return{isOrg:true,org:m2[2],provider:'gitlab',baseUrl:m2[1]};
  }
  return{isOrg:false};
}

function wizDiscoverOrgRepos(orgName,provider,opts){
  opts=opts||{};
  var pickerEl=$('#wiz-org-repo-picker');
  if(!pickerEl)return;
  _orgDiscoveryState={loading:true,repos:[],org:orgName,provider:provider,error:''};
  _renderOrgRepoPicker();

  var token=$('#src-remote-token')?$('#src-remote-token').value.trim():'';
  var endpoint,body;
  if(provider==='github'){
    endpoint='/api/github/org-repos';
    body={org:orgName,token:token};
  }else{
    endpoint='/api/gitlab/group-repos';
    body={group:orgName,token:token};
    if(opts.baseUrl)body.gitlab_url=opts.baseUrl;
  }

  fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)})
    .then(function(r){return r.json()})
    .then(function(d){
      _orgDiscoveryState.loading=false;
      if(d.ok){
        _orgDiscoveryState.repos=d.repos||[];
        if(!_orgDiscoveryState.repos.length){
          _orgDiscoveryState.error=_t('ui.wizard.org_no_repos');
        }
      }else{
        _orgDiscoveryState.error=d.error||_t('ui.error.generic');
      }
      _renderOrgRepoPicker();
    })
    .catch(function(e){
      _orgDiscoveryState.loading=false;
      _orgDiscoveryState.error=e.message||_t('ui.error.generic');
      _renderOrgRepoPicker();
    });
}

function _renderOrgRepoPicker(){
  var el=$('#wiz-org-repo-picker');
  if(!el)return;
  var st=_orgDiscoveryState;
  if(!st.org){hideEl(el);return}
  showEl(el);

  if(st.loading){
    el.innerHTML='<div class="text-secondary" style="padding:12px 0">'+_t('ui.wizard.org_loading')+' <strong>'+esc(st.org)+'</strong>…</div>';
    return;
  }
  if(st.error){
    el.innerHTML='<div class="alert alert-error" style="margin:8px 0">'+esc(st.error)+'</div>'
      +'<button class="btn btn-sm mt-1" onclick="wizCloseOrgPicker()">'+_t('ui.modal.close')+'</button>';
    return;
  }
  var repos=st.repos;
  var h='<div class="wiz-org-picker-header">';
  h+='<strong>'+esc(st.org)+'</strong> &mdash; '+repos.length+' '+_t('ui.wizard.org_repos_found');
  h+='<div class="flex gap-1 mt-1 mb-1"><button class="btn btn-sm" onclick="wizOrgSelectAll(true)">'+_t('ui.wizard.org_select_all')+'</button>';
  h+='<button class="btn btn-sm" onclick="wizOrgSelectAll(false)">'+_t('ui.wizard.org_deselect_all')+'</button></div>';
  h+='</div>';
  h+='<div class="wiz-org-picker-list" style="max-height:280px;overflow-y:auto">';
  repos.forEach(function(r,i){
    var already=_wizSourceState.remoteRepos.some(function(rr){return rr.url===r.url});
    var vis=r.visibility==='private'?'&#128274;':'&#127760;';
    h+='<label class="wiz-org-picker-item'+(already?' disabled':'')+'">';
    h+='<input type="checkbox" data-org-idx="'+i+'"'+(already?' disabled checked':'')+' />';
    h+='<span>'+vis+' <strong>'+esc(r.name)+'</strong>';
    if(r.description)h+=' <span class="text-tertiary">&mdash; '+esc(r.description.substring(0,80))+'</span>';
    h+='</span></label>';
  });
  h+='</div>';
  h+='<div class="flex gap-1 mt-1">';
  h+='<button class="btn btn-primary btn-sm" onclick="wizOrgAddSelected()">'+_t('ui.wizard.org_add_selected')+'</button>';
  h+='<button class="btn btn-sm" onclick="wizCloseOrgPicker()">'+_t('ui.modal.cancel')+'</button>';
  h+='</div>';
  el.innerHTML=h;
}

function wizOrgSelectAll(val){
  var cbs=$$('#wiz-org-repo-picker input[type=checkbox]:not(:disabled)');
  cbs.forEach(function(cb){cb.checked=val});
}

function wizOrgAddSelected(){
  var cbs=$$('#wiz-org-repo-picker input[type=checkbox]:not(:disabled):checked');
  var repos=_orgDiscoveryState.repos;
  var provider=_orgDiscoveryState.provider;
  var added=0;
  cbs.forEach(function(cb){
    var idx=parseInt(cb.getAttribute('data-org-idx'),10);
    var r=repos[idx];
    if(!r)return;
    var already=_wizSourceState.remoteRepos.some(function(rr){return rr.url===r.url});
    if(already)return;
    _wizSourceState.remoteRepos.push({
      url:r.url,
      label:r.full_name||r.name,
      provider:provider,
      owner:r.full_name?r.full_name.split('/')[0]:'',
      repo:r.name,
      projectPath:r.full_name||'',
      inspected:false
    });
    added++;
  });
  wizCloseOrgPicker();
  if(added>0){
    $('#src-multi-repo-url').value='';
    $('#src-multi-repo-label').value='';
    wizRenderMultiRepoList();
    _wizUpdateNextBtn();
  }
}

function wizCloseOrgPicker(){
  _orgDiscoveryState={loading:false,repos:[],org:'',provider:'',error:''};
  var el=$('#wiz-org-repo-picker');
  if(el){el.innerHTML='';hideEl(el)}
}

function wizAddMultiRepo(){
  _wizClearFieldError('#src-multi-repo-url','#err-multi-repo-url');
  var url=$('#src-multi-repo-url').value.trim();
  var label=$('#src-multi-repo-label').value.trim();
  if(!url){_wizShowFieldError('#src-multi-repo-url','#err-multi-repo-url',_t('ui.wizard.err_repo_url_add'));return}

  /* Protocol check */
  if(!/^https?:\/\//i.test(url)){
    _wizShowFieldError('#src-multi-repo-url','#err-multi-repo-url',_t('ui.wizard.err_url_protocol'));
    return;
  }

  /* Provider-specific URL format validation */
  if(_wizSourceState.provider==='github'){
    /* Detect org/user pages → trigger discovery instead of rejecting */
    var orgCheck=_wizDetectOrgUrl(url);
    if(orgCheck.isOrg){
      wizDiscoverOrgRepos(orgCheck.org,'github');
      return;
    }
    if(!_GH_URL_RE.test(url)){
      _wizShowFieldError('#src-multi-repo-url','#err-multi-repo-url',_t('ui.wizard.err_github_url_format'));
      return;
    }
  }else{
    var glOrgCheck=_wizDetectOrgUrl(url);
    if(glOrgCheck.isOrg){
      wizDiscoverOrgRepos(glOrgCheck.org,'gitlab',{baseUrl:glOrgCheck.baseUrl});
      return;
    }
    if(!_GL_URL_RE.test(url)){
      _wizShowFieldError('#src-multi-repo-url','#err-multi-repo-url',_t('ui.wizard.err_gitlab_repo_url_format'));
      return;
    }
  }

  /* Check for duplicates */
  for(var i=0;i<_wizSourceState.remoteRepos.length;i++){
    if(_wizSourceState.remoteRepos[i].url===url){
      _wizShowFieldError('#src-multi-repo-url','#err-multi-repo-url',_t('ui.wizard.err_repo_duplicate'));
      return;
    }
  }

  fetch('/api/sources/validate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({url:url,token:$('#src-remote-token').value.trim(),app_label:label})})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.ok){
        _wizSourceState.remoteRepos.push({
          url:url,
          label:label||d.display_name||url,
          provider:d.source_type,
          owner:d.owner||'',
          repo:d.repo||'',
          projectPath:d.project_path||'',
          inspected:false
        });
        $('#src-multi-repo-url').value='';
        $('#src-multi-repo-label').value='';
        wizRenderMultiRepoList();
        _wizUpdateNextBtn();
      }else{
        openModal(_t('ui.wizard.err_validation_title'),'<p>'+esc(d.error||_t('ui.wizard.err_url_validate_failed'))+'</p>','<button class="btn btn-secondary" onclick="closeModal()">'+_t('ui.modal.ok')+'</button>');
      }
    })
    .catch(function(e){
      openModal(_t('ui.error.generic'),'<p>'+esc(e.message||_t('ui.wizard.err_url_validate_failed'))+'</p>','<button class="btn btn-secondary" onclick="closeModal()">'+_t('ui.modal.ok')+'</button>');
    });
}

function wizRemoveMultiRepo(idx){
  _wizSourceState.remoteRepos.splice(idx,1);
  wizRenderMultiRepoList();
  _wizUpdateNextBtn();
}

function wizRenderMultiRepoList(){
  var el=$('#wiz-multi-repo-list');
  if(!el)return;
  var repos=_wizSourceState.remoteRepos;
  if(!repos.length){
    el.innerHTML='<div class="text-tertiary" style="padding:12px 0">'+_t('ui.wizard.no_repos_added')+'</div>';
    return;
  }
  var h='<div class="wiz-multi-repos">';
  repos.forEach(function(r,i){
    var icon=r.provider==='github'?'&#128025;':r.provider==='gitlab'?'&#129418;':'&#128193;';
    h+='<div class="wiz-multi-repo-item">';
    h+='<span class="wiz-multi-repo-icon">'+icon+'</span>';
    h+='<span class="wiz-multi-repo-label"><strong>'+esc(r.label)+'</strong></span>';
    h+='<span class="wiz-multi-repo-url text-tertiary">'+esc(r.url)+'</span>';
    h+='<button class="btn btn-sm wiz-multi-repo-remove" onclick="wizRemoveMultiRepo('+i+')" title="Remove">&#10060;</button>';
    h+='</div>';
  });
  h+='</div>';
  el.innerHTML=h;
}

/* ===== STEP 3: SCOPE ===== */

function renderWizScopeStep(){
  /* Clear stale preview stats immediately */
  var preview=$('#wiz-scope-preview');if(preview)preview.innerHTML='';
  var alerts=$('#src-alerts');if(alerts)alerts.innerHTML='';

  /* Show scope banner with repo count */
  var banner=$('#wiz-scope-banner');
  var countEl=$('#wiz-scope-repo-count');
  var repoCount=_getRepoCount();
  if(repoCount>1){
    showEl(banner);
    countEl.textContent=repoCount;
    banner.innerHTML='&#128279; '+_t('ui.wizard.scope_banner_multi').replace('{count}',repoCount);
  }else if(_wizSourceState.sourceType==='remote'){
    showEl(banner);
    banner.innerHTML='&#128279; '+_t('ui.wizard.scope_banner_remote');
  }else{
    hideEl(banner);
  }

  var h='';
  var hasFromRef=!!D.from_ref;
  var defaultRef=hasFromRef;

  /* Range mode selector */
  h+='<div class="section"><div class="section-title">'+_t('ui.wizard.source_range')+'</div>';
  h+='<div class="wizard-options wiz-src-grid">';
  h+='<div class="wizard-option'+(defaultRef?'':' selected')+'" id="src-opt-date" tabindex="0" role="radio" aria-checked="'+(defaultRef?'false':'true')+'" onclick="srcSelectMode(\'date\')" onkeydown="if(event.key===\'Enter\')srcSelectMode(\'date\')">';
  h+='<div class="wizard-option-icon">&#128197;</div>';
  h+='<div class="wizard-option-label">'+_t('ui.wizard.src_date_label')+'</div>';
  h+='<div class="wizard-option-desc">'+_t('ui.wizard.src_date_desc')+'</div>';
  h+='</div>';
  h+='<div class="wizard-option'+(defaultRef?' selected':'')+'" id="src-opt-ref" tabindex="0" role="radio" aria-checked="'+(defaultRef?'true':'false')+'" onclick="srcSelectMode(\'ref\')" onkeydown="if(event.key===\'Enter\')srcSelectMode(\'ref\')">';
  h+='<div class="wizard-option-icon">&#127991;&#65039;</div>';
  h+='<div class="wizard-option-label">'+_t('ui.wizard.src_ref_label')+'</div>';
  h+='<div class="wizard-option-desc">'+_t('ui.wizard.src_ref_desc')+'</div>';
  h+='</div>';
  h+='</div>';

  /* Date mode fields */
  var now=new Date();
  var presets=[{key:'1m',months:1},{key:'2m',months:2},{key:'3m',months:3},{key:'1y',months:12}];
  var restoredDate=D.since_date||'';
  var matchedPreset='custom';
  if(restoredDate){
    presets.forEach(function(p){
      var d=new Date(now.getFullYear(),now.getMonth()-p.months,now.getDate());
      if(_localIso(d)===restoredDate)matchedPreset=p.key;
    });
  }else{
    matchedPreset='1m';
    restoredDate=_localIso(new Date(now.getFullYear(),now.getMonth()-1,now.getDate()));
  }

  h+='<div id="src-panel-date" class="src-fields'+(defaultRef?' hidden':'')+'">';
  h+='<div class="export-row"><label>'+_t('ui.wizard.src_preset_label')+'</label>';
  h+='<div class="src-presets">';
  presets.forEach(function(p){
    var sel=p.key===matchedPreset?' selected':'';
    h+='<button class="btn btn-sm src-preset'+sel+'" data-preset="'+p.key+'" onclick="srcPreset(\''+p.key+'\','+p.months+')">'+_t('ui.wizard.src_preset_'+p.key)+'</button>';
  });
  h+='<button class="btn btn-sm src-preset'+(matchedPreset==='custom'?' selected':'')+'" data-preset="custom" onclick="srcPresetCustom()">'+_t('ui.wizard.src_preset_custom')+'</button>';
  h+='</div></div>';
  h+='<div class="wiz-field-group"><label for="src-since-date">'+_t('ui.first_run.since_label')+' <span class="text-error">*</span></label>';
  h+='<input type="date" id="src-since-date" class="form-input" value="'+esc(restoredDate)+'" onchange="_syncPresetChips();_wizUpdateNextBtn();srcAutoReload()">';
  h+='<span class="wiz-helper-text">'+_t('ui.wizard.scope_date_hint')+'</span>';
  h+='<div class="field-error" id="err-since-date"></div></div>';
