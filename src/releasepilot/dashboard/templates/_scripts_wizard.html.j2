function _getRepoCount(){
  if(_wizSourceState.sourceType==='remote'&&_wizSourceState.repoCount==='multi'){
    return _wizSourceState.remoteRepos.length||0;
  }
  if(_wizSourceState.sourceType==='local'&&_wizSourceState.localMode==='directory'){
    return (_wizSourceState.selectedLocalRepos||[]).length||0;
  }
  return 1;
}

