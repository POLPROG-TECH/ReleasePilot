  var isNarr=(aud==='narrative'||aud==='customer-narrative');
  var allowed;
  if(isExec){
    allowed=['pdf','docx','markdown','json'];
  } else if(isNarr){
    allowed=['pdf','docx','markdown','plaintext','json'];
  } else {
    allowed=['markdown','plaintext','json'];
  }
  if(allowed.indexOf(S.wizard.format)<0){
    S.wizard.format=allowed[0];
